#!/usr/bin/env python3
"""Stop meeting recording, restore audio output, and optionally transcribe."""
import os, sys, signal, time, subprocess

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
PROJECT_ROOT = os.path.dirname(SCRIPT_DIR)

def restore_audio_output():
    """Restore the original audio output device if we saved one."""
    output_file = "/tmp/meetrecord.output"
    if os.path.exists(output_file):
        with open(output_file) as f:
            original_output = f.read().strip()
        if original_output:
            switcher = os.path.join(PROJECT_ROOT, "src/swift/set-default-output")
            try:
                subprocess.run([switcher, original_output], check=True, capture_output=True)
                print(f"Restored audio output to: {original_output}")
            except (subprocess.CalledProcessError, OSError) as e:
                print(f"Warning: could not restore output to '{original_output}': {e}")
        os.remove(output_file)

def main():
    transcribe = "--transcribe" in sys.argv
    model = "base"
    args = sys.argv[1:]
    i = 0
    while i < len(args):
        if args[i] == "--model" and i + 1 < len(args):
            model = args[i + 1]
            i += 2
        else:
            i += 1

    pid_file = "/tmp/meetrecord.pid"
    lastfile = "/tmp/meetrecord.lastfile"

    if not os.path.exists(pid_file):
        print("No active recording found.")
        restore_audio_output()
        sys.exit(1)

    pid = None
    try:
        with open(pid_file) as f:
            pid = int(f.read().strip())
    except ValueError:
        print("Warning: corrupt PID file. Cleaning up.")
        os.remove(pid_file)
        restore_audio_output()
        if os.path.exists(lastfile):
            os.remove(lastfile)
        sys.exit(1)

    name = None
    if os.path.exists(lastfile):
        with open(lastfile) as f:
            name = f.read().strip()

    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        print("Recording process not running.")
        os.remove(pid_file)
        if os.path.exists(lastfile):
            os.remove(lastfile)
        restore_audio_output()
        sys.exit(1)

    print(f"Stopping recording (PID: {pid})...")
    os.kill(pid, signal.SIGINT)

    # Wait up to 30 seconds for the recorder to finish writing files
    exited = False
    for _ in range(100):
        try:
            os.kill(pid, 0)
            time.sleep(0.3)
        except ProcessLookupError:
            exited = True
            break

    if not exited:
        print("Warning: recorder did not exit gracefully, sending SIGTERM...")
        try:
            os.kill(pid, signal.SIGTERM)
            for _ in range(20):
                try:
                    os.kill(pid, 0)
                    time.sleep(0.3)
                except ProcessLookupError:
                    exited = True
                    break
        except ProcessLookupError:
            exited = True

    if not exited:
        print("Warning: recorder still running after SIGTERM.")

    os.remove(pid_file)
    restore_audio_output()

    out_dir = os.path.expanduser("~/Desktop/recordings")

    if name:
        combined = os.path.join(out_dir, f"{name}_combined.wav")
        mic = os.path.join(out_dir, f"{name}_mic.wav")
        system = os.path.join(out_dir, f"{name}_system.wav")
        legacy = os.path.join(out_dir, f"{name}.wav")

        # If recorder is still finalizing, give files a moment to appear
        for _ in range(10):
            if os.path.exists(combined) or os.path.exists(legacy):
                break
            time.sleep(0.5)

        if os.path.exists(combined):
            print(f"Saved: {combined}")
            if os.path.exists(mic):
                print(f"       {mic}")
            if os.path.exists(system):
                print(f"       {system}")
            target = combined
        elif os.path.exists(legacy):
            print(f"Saved: {legacy}")
            target = legacy
        else:
            print("Warning: output file not found.")
            target = None

        if target and transcribe:
            print(f"Transcribing with model '{model}'...")
            subprocess.run([
                sys.executable,
                os.path.join(PROJECT_ROOT, "src/python/mac-transcribe.py"),
                target,
                "--model", model
            ])
    else:
        print("Warning: recording name not found.")

    if os.path.exists(lastfile):
        os.remove(lastfile)

if __name__ == "__main__":
    main()
