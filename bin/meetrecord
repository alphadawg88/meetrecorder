#!/usr/bin/env python3
"""Start dual-channel meeting recording in background (mic + system audio)."""
import os, sys, subprocess, time, signal

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
PROJECT_ROOT = os.path.dirname(SCRIPT_DIR)

def get_default_output_name():
    try:
        import sounddevice as sd
        return sd.query_devices(sd.default.device[1])["name"]
    except Exception:
        return None

def main():
    device = None
    name = None
    args = sys.argv[1:]
    i = 0
    while i < len(args):
        if args[i] == "--device" and i + 1 < len(args):
            device = args[i + 1]
            i += 2
        elif args[i] == "--name" and i + 1 < len(args):
            name = args[i + 1]
            i += 2
        else:
            i += 1

    if not name:
        from datetime import datetime
        name = "meeting_" + datetime.now().strftime("%Y%m%d_%H%M%S")

    out_dir = os.path.expanduser("~/Desktop/recordings")
    os.makedirs(out_dir, exist_ok=True)

    pid_file = "/tmp/meetrecord.pid"
    lastfile = "/tmp/meetrecord.lastfile"
    output_file = "/tmp/meetrecord.output"

    if os.path.exists(pid_file):
        try:
            with open(pid_file) as f:
                old_pid = int(f.read().strip())
            os.kill(old_pid, signal.SIGINT)
            # Poll for exit instead of fixed sleep
            for _ in range(30):
                try:
                    os.kill(old_pid, 0)
                    time.sleep(0.2)
                except (ProcessLookupError, ValueError, PermissionError):
                    break
        except (ProcessLookupError, ValueError, PermissionError):
            pass
        os.remove(pid_file)

    # Save current default output device for restoration later
    original_output = get_default_output_name()
    if original_output and "Background Music" not in original_output:
        with open(output_file, "w") as f:
            f.write(original_output)
    elif os.path.exists(output_file):
        os.remove(output_file)

    # Switch system audio output to Background Music so call audio is captured
    switcher = os.path.join(PROJECT_ROOT, "src/swift/set-default-output")
    try:
        subprocess.run([switcher, "Background Music"], check=True, capture_output=True)
        print("Switched audio output to Background Music")
    except (subprocess.CalledProcessError, OSError) as e:
        print(f"Warning: could not switch output to Background Music: {e}")

    cmd = [sys.executable, os.path.join(PROJECT_ROOT, "src/python/dual-record.py"), "--name", name]
    if device:
        cmd += ["--device", device]

    print(f"Recording meeting: {name}")
    print("Stop with: meetstop")

    proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    with open(pid_file, "w") as f:
        f.write(str(proc.pid))
    with open(lastfile, "w") as f:
        f.write(name)

    print(f"Started (PID: {proc.pid})")

if __name__ == "__main__":
    main()
