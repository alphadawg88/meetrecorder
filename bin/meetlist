#!/usr/bin/env python3
"""List recent recordings."""
import os, glob

def main():
    import sys
    limit = int(sys.argv[1]) if len(sys.argv) > 1 else 10
    out_dir = os.path.expanduser("~/Desktop/recordings")

    files = sorted(glob.glob(os.path.join(out_dir, "*.wav")), key=os.path.getmtime, reverse=True)

    print(f"Recent recordings in {out_dir}:")
    print("-" * 60)
    for f in files[:limit]:
        size = os.path.getsize(f)
        unit = "B"
        if size > 1024:
            size /= 1024
            unit = "KB"
        if size > 1024:
            size /= 1024
            unit = "MB"
        mtime = os.path.getmtime(f)
        import datetime
        ts = datetime.datetime.fromtimestamp(mtime).strftime("%Y-%m-%d %H:%M")
        print(f"  {ts}  {size:6.1f} {unit:2}  {os.path.basename(f)}")

if __name__ == "__main__":
    main()
